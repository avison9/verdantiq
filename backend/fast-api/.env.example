# FastAPI application settings
# Copy this file to .env and fill in values before running

# -------------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/test_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test_db

# -------------------------------------------------------
# JWT Authentication
# IMPORTANT: generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------
SECRET_KEY=changeme-in-production-generate-with-secrets-token-hex-32
ALGORITHM=HS256

# -------------------------------------------------------
# Trino (data warehouse query engine)
# -------------------------------------------------------
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=trino
TRINO_CATALOG=iceberg
TRINO_SCHEMA=default
