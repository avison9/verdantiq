# =============================================================================
#  VerdantIQ — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=verdantiq
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-in-production

# ── JWT (shared across all backend services) ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-generate-with-secrets-token-hex-32
ALGORITHM=HS256

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# For local dev this should be the Vite dev server origin
ALLOWED_ORIGINS=http://localhost:5173

# ── Inter-service URLs ─────────────────────────────────────────────────────────
TENANT_SERVICE_URL=http://tenant:8002

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-in-production

# ── Trino (analytics query engine) ───────────────────────────────────────────
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=user
TRINO_CATALOG=iceberg
TRINO_SCHEMA=sensors

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
